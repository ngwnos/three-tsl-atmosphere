{
  "name": "three-tsl-atmosphere",
  "version": "0.1.0",
  "description": "Reusable Bruneton-style precomputed atmosphere LUT system for three.js TSL/WebGPU",
  "type": "module",
  "workspaces": [
    "demo"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:lib",
    "build:lib": "tsup src/index.ts --format esm --clean && cp src/index.d.ts dist/index.d.ts",
    "build:demo": "bun run --cwd demo build",
    "dev": "bun run dev:lib",
    "dev:lib": "tsup src/index.ts --format esm --watch",
    "dev:demo": "bun run --cwd demo dev",
    "preview": "bun run --cwd demo preview",
    "preview:orca": "bun run --cwd demo preview"
  },
  "keywords": [
    "three",
    "webgpu",
    "tsl",
    "atmosphere",
    "bruneton",
    "scattering"
  ],
  "license": "BSD-3-Clause",
  "peerDependencies": {
    "three": "^0.182.0 || ^0.183.0"
  },
  "devDependencies": {
    "@types/three": "^0.183.0",
    "three": "^0.183.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
